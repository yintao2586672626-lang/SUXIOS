            // 操作日志相关
            const operationLogs = ref([]);
            const logModules = ref([]);
            const logActions = ref([]);
            const logUsers = ref([]);
            const logHotels = ref([]);
            const logFilter = ref({
                module: '',
                action: '',
                user_id: '',
                hotel_id: '',
                start_date: '',
