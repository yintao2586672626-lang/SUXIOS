        },
        {
          "metric_key": "ctrip_visitor_peer_avg",
          "raw_label": "竞争圈平均",
          "value_type": "number",
          "unit": "people",
          "storage_target": "online_daily_data.raw_data.metrics.visitor_peer_avg",
          "missing_state": "traffic_peer_avg_missing"
        },
        {
          "metric_key": "ctrip_order_conversion_rate",
          "raw_label": "实时下单转化率",
          "value_type": "percent",
          "unit": "percent",
          "storage_target": "online_daily_data.raw_data.metrics.order_conversion_rate",
          "missing_state": "traffic_conversion_missing"
        },
        {
          "metric_key": "ctrip_realtime_rank",
          "raw_label": "实时排名",
          "value_type": "integer",
          "unit": "rank",
          "storage_target": "online_daily_data.raw_data.rank_metrics.realtime_rank",
          "missing_state": "rank_missing"
        }
      ]
    },
    {
      "platform": "ctrip",
      "channel": "qunar",
      "module": "traffic_realtime",
      "priority": "P0",
      "source_url_alias": "ctrip_flowdata_qunar_tab",
      "fields": [
        {
          "metric_key": "qunar_realtime_visitors",
          "raw_label": "实时访客量",
          "value_type": "integer",
          "unit": "people",
          "storage_target": "online_daily_data.raw_data.metrics.qunar_realtime_visitors",
          "missing_state": "traffic_visitors_missing"
        },
        {
          "metric_key": "qunar_visitor_peer_avg",
          "raw_label": "竞争圈平均",
          "value_type": "number",
          "unit": "people",
          "storage_target": "online_daily_data.raw_data.metrics.qunar_visitor_peer_avg",
          "missing_state": "traffic_peer_avg_missing"
        },
        {
          "metric_key": "qunar_order_conversion_rate",
          "raw_label": "实时下单转化率",
          "value_type": "percent",
          "unit": "percent",
          "storage_target": "online_daily_data.raw_data.metrics.qunar_order_conversion_rate",
          "missing_state": "traffic_conversion_missing"
        }
      ]
    }
  ],
  "required_evidence_fields": [
    "platform",
    "module",
    "collection_mode",
    "source_url_alias",
    "source_path",
    "metric_key",
    "raw_label",
    "value_type",
    "unit",
    "data_date",
    "storage_target",
    "missing_state"
  ],
  "forbidden_behaviors": [
    "bypass_login_or_captcha",
    "store_or_commit_cookie_token_profile",
    "hide_empty_or_failed_collection",
    "use_dom_when_business_json_is_available_without_reason",
    "promote_ota_channel_data_to_whole_hotel_truth"
  ],
  "acceptance_checks": [
    "P0 realtime traffic and rank fields have metric_key and missing_state.",
    "DOM evidence is labeled as browser_assist_dom.",
    "Default storage remains online_daily_data.raw_data.",
    "Login expired, endpoint miss, selector miss, and empty value remain explicit states.",
    "AI and revenue modules consume only data with visible quality state."
  ]
}
