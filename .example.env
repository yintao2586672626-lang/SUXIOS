# ============================================================
# 宿析OS 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# 调试模式（生产环境设为 false）
APP_DEBUG = false

# 运行环境（local / dev / production）。生产环境建议显式设置为 production。
APP_ENV = local

# -------------------- 数据库配置 --------------------
# 数据库类型（mysql / sqlite）
DB_TYPE = mysql

# MySQL 主机地址
DB_HOST = 127.0.0.1

# 数据库名（需提前创建）
DB_NAME = hotelx

# 数据库用户名
DB_USER = root

# 数据库密码（本地开发环境通常为空）
DB_PASS =

# MySQL 端口
DB_PORT = 3306

# 字符集（务必使用 utf8mb4，否则中文会乱码）
DB_CHARSET = utf8mb4

# 表前缀（通常留空）
DB_PREFIX =

# -------------------- 隔离 E2E 配置 --------------------
# 快速 E2E 默认使用此专用测试库，并在本机 18080 端口自启临时 PHP 服务。
# 先在本机创建并用 database/init_full.sql 初始化；不得填写生产库名。
SUXI_E2E_DB_NAME = hotelx_e2e
SUXI_E2E_APP_PORT = 18080

# 手动 OTA 后台任务状态默认写入数据库，供使用同一数据库的多节点共享；
# file 仅用于本机兼容或测试。配置未实现的 driver 会显式失败，不得静默回退。
SUXI_MANUAL_FETCH_TASK_STATUS_DRIVER = database
# 已完成或长期遗留的任务目录默认保留 7 天；允许范围 3600–7776000 秒。
SUXI_MANUAL_FETCH_TASK_RETENTION_SECONDS = 604800
# queued/running 超过此时间会先转为 timeout，再从 timeout 时刻计算保留期；低于 7500 会按 7500 执行。
SUXI_MANUAL_FETCH_TASK_STALE_SECONDS = 7500
# 合法任务目录缺失或损坏 status.json 时，按孤儿目录保留 24 小时后清理。
SUXI_MANUAL_FETCH_TASK_ORPHAN_SECONDS = 86400

# -------------------- 其他配置 --------------------
# 默认语言
DEFAULT_LANG = zh-cn

# -------------------- 安全配置 --------------------
# 首次执行 db:init 时可显式指定初始密码（12-128字符）。留空则分别生成
# 高强度一次性密码并只在初始化控制台显示一次；不得在生产配置中复用示例密码。
SUXI_BOOTSTRAP_ADMIN_PASSWORD =
SUXI_BOOTSTRAP_MANAGER_PASSWORD =
SUXI_BOOTSTRAP_STAFF_PASSWORD =

# 浏览器跨域来源白名单，逗号分隔且禁止使用 *。同源部署无需额外来源；
# 前后端分域部署时必须在上线前替换为真实 HTTPS 前端 Origin。
CORS_ALLOWED_ORIGINS = http://127.0.0.1:8080,http://localhost:8080
CORS_ALLOW_CREDENTIALS = true
CORS_MAX_AGE = 600

# 竞对采集不再使用部署级全局 Token。请由超管通过
# /api/admin/competitor-devices 创建“设备 + 平台 + 门店”绑定，并保存只显示一次的设备 Token。

# 自动抓取定时任务 token。生产环境必须设置为足够长的随机字符串，并同步 X-Cron-Token。
CRON_TOKEN =

# OTA 详细调试日志。默认关闭，开启后可能记录第三方接口响应结构和业务样例。
OTA_DEBUG_LOG = false

# OTA 请求默认校验证书；仅本地调试证书问题时可设为 false。
OTA_SSL_VERIFY = true

# Base64-encoded 32-byte key for AES-256-GCM OTA credential envelopes. Never commit the real value.
OTA_CREDENTIAL_KEY_B64 =

# Key identifier stored in OTA credential envelopes for explicit key selection. Do not put a real value in this template.
OTA_CREDENTIAL_KEY_ID =

# Optional dedicated Base64-encoded 32-byte key for system secrets and enterprise WeChat webhooks.
# When both values are empty, the application derives a separate domain key from the OTA credential key above.
SUXI_SECRET_KEY_B64 =
SUXI_SECRET_KEY_ID =

# -------------------- LLM 配置 --------------------
# OpenAI compatible API key. Do not put a real key in this template.
OPENAI_API_KEY =

# DeepSeek OpenAI compatible API. Do not put a real key in this template.
DEEPSEEK_API_KEY =
DEEPSEEK_BASE_URL = https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL = deepseek-v4-flash
DEEPSEEK_FAST_MODEL = deepseek-v4-flash
DEEPSEEK_PRO_MODEL = deepseek-v4-pro
DEEPSEEK_TIMEOUT = 60

# OpenAI compatible API base URL, usually ending with /v1.
OPENAI_BASE_URL = https://api.openai.com/v1

# Default model name. Configure it according to your provider/account.
OPENAI_MODEL = your-model-name

# Secret used to encrypt/decrypt AI model API keys stored in database.
# Set a long random string in local .env; never commit the real value.
AI_CONFIG_SECRET =

# -------------------- 智略·战略推演数据源 --------------------
# 高德 POI 搜索 Key，未配置时自动降级为本地数据推演
AMAP_KEY =

# 高德天气/外部信号 Web API Key。未配置时后端会回退使用 AMAP_KEY。
AMAP_WEB_API_KEY =

# 百度 Place API Key，第一版作为备用数据源配置
BAIDU_MAP_KEY =

# 战略推演外部数据快照缓存小时数
STRATEGY_DATA_CACHE_HOURS = 24
