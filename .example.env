# ============================================================
# 宿析OS 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# 调试模式（生产环境设为 false）
APP_DEBUG = true

# -------------------- 数据库配置 --------------------
# 数据库类型（mysql / sqlite）
DB_TYPE = mysql

# MySQL 主机地址
DB_HOST = 127.0.0.1

# 数据库名（需提前创建）
DB_NAME = hotelx

# 数据库用户名
DB_USER = root

# 数据库密码（本地开发环境通常为空）
DB_PASS =

# MySQL 端口
DB_PORT = 3306

# 字符集（务必使用 utf8mb4，否则中文会乱码）
DB_CHARSET = utf8mb4

# 表前缀（通常留空）
DB_PREFIX =

# -------------------- 其他配置 --------------------
# 默认语言
DEFAULT_LANG = zh-cn
