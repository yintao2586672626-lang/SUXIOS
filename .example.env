# ============================================================
# 宿析OS 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# 调试模式（生产环境设为 false）
APP_DEBUG = true

# -------------------- 数据库配置 --------------------
# 数据库类型（mysql / sqlite）
DB_TYPE = mysql

# MySQL 主机地址
DB_HOST = 127.0.0.1

# 数据库名（需提前创建）
DB_NAME = hotelx

# 数据库用户名
DB_USER = root

# 数据库密码（本地开发环境通常为空）
DB_PASS =

# MySQL 端口
DB_PORT = 3306

# 字符集（务必使用 utf8mb4，否则中文会乱码）
DB_CHARSET = utf8mb4

# 表前缀（通常留空）
DB_PREFIX =

# -------------------- 其他配置 --------------------
# 默认语言
DEFAULT_LANG = zh-cn

# -------------------- LLM 配置 --------------------
# OpenAI compatible API key. Do not put a real key in this template.
OPENAI_API_KEY =

# DeepSeek API key. Do not put a real key in this template.
DEEPSEEK_API_KEY =

# DeepSeek OpenAI compatible API base URL.
DEEPSEEK_BASE_URL = https://api.deepseek.com/v1

# OpenAI compatible API base URL, usually ending with /v1.
OPENAI_BASE_URL = https://api.openai.com/v1

# Default model name. Configure it according to your provider/account.
OPENAI_MODEL = your-model-name

# Secret used to encrypt/decrypt AI model API keys stored in database.
# Set a long random string in local .env; never commit the real value.
AI_CONFIG_SECRET =

# -------------------- 智略·战略推演数据源 --------------------
# 高德 POI 搜索 Key，未配置时自动降级为本地数据推演
AMAP_KEY =

# 百度 Place API Key，第一版作为备用数据源配置
BAIDU_MAP_KEY =

# 战略推演外部数据快照缓存小时数
STRATEGY_DATA_CACHE_HOURS = 24
