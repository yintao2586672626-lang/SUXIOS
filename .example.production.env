# Copy this file to a controlled location outside Git, then set RELEASE_ENV_FILE to that path.
# Do not commit real production secrets.

APP_DEBUG=false
APP_TRACE=false
APP_TIMEZONE=Asia/Shanghai

DB_TYPE=mysql
DB_HOST=CHANGE_ME_PRODUCTION_DB_HOST
DB_NAME=CHANGE_ME_PRODUCTION_DB_NAME
DB_USER=CHANGE_ME_LEAST_PRIVILEGE_DB_USER
DB_PASS=CHANGE_ME_STRONG_DB_PASSWORD
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_PREFIX=

# Must match the secret used when saving encrypted ai_model_configs.api_key_encrypted.
AI_CONFIG_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET

# LLM provider API keys are configured through the AI model config UI / database,
# not through env-based OpenAIClient.
